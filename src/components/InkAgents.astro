---
// Hero background: simple agents wander, then gradually align into flowing
// ink streams — emergence, drawn in sumi ink. Pure canvas, no dependencies.
---

<canvas class="ink-agents" data-ink-agents aria-hidden="true"></canvas>

<style>
  .ink-agents {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('[data-ink-agents]');

  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const DPR = Math.min(devicePixelRatio || 1, 2);
    const PAPER = '#faf9f5';
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    interface Agent {
      x: number;
      y: number;
      px: number;
      py: number;
      a: number; // heading
      w: number; // stroke weight
      d: number; // ink density
    }

    let agents: Agent[] = [];
    let W = 0;
    let H = 0;
    let order = 0; // 0 = disorder, 1 = coordinated flow
    let raf = 0;
    let running = false;
    let last = 0;

    const rand = (lo: number, hi: number) => lo + Math.random() * (hi - lo);

    function resize() {
      const rect = canvas.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      canvas.width = Math.round(W * DPR);
      canvas.height = Math.round(H * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      ctx.fillStyle = PAPER;
      ctx.fillRect(0, 0, W, H);
      seed();
    }

    function seed() {
      const n = Math.min(110, Math.max(40, Math.round((W * H) / 14000)));
      agents = Array.from({ length: n }, () => {
        const x = rand(0, W);
        const y = rand(0, H);
        return {
          x,
          y,
          px: x,
          py: y,
          a: rand(0, Math.PI * 2),
          w: rand(0.6, 2.2),
          d: rand(0.09, 0.22),
        };
      });
      order = 0;
    }

    function step(dt: number) {
      // Order slowly rises: coordination emerges, then is perturbed again.
      order = Math.min(1, order + dt * 0.028);
      if (order >= 1 && Math.random() < 0.004) {
        for (const g of agents) g.a += rand(-2.4, 2.4);
        order = 0.05;
      }

      const R = 46; // neighbourhood radius
      const speed = 34 + 26 * order; // px / second

      for (const g of agents) {
        // Alignment with neighbours, weighted by current order
        let sx = 0;
        let sy = 0;
        let n = 0;
        for (const o of agents) {
          if (o === g) continue;
          const dx = o.x - g.x;
          const dy = o.y - g.y;
          if (dx * dx + dy * dy < R * R) {
            sx += Math.cos(o.a);
            sy += Math.sin(o.a);
            n++;
          }
        }
        if (n > 0) {
          const target = Math.atan2(sy / n, sx / n);
          let diff = target - g.a;
          diff = Math.atan2(Math.sin(diff), Math.cos(diff));
          g.a += diff * (0.5 + 1.6 * order) * dt;
        }

        // Wander: strong while disordered, fades as coordination emerges
        g.a += rand(-1, 1) * (1.6 - 1.25 * order) * dt * 2.6;

        g.px = g.x;
        g.py = g.y;
        g.x += Math.cos(g.a) * speed * dt;
        g.y += Math.sin(g.a) * speed * dt;

        // Wrap edges without drawing the jump
        let wrapped = false;
        if (g.x < -4) { g.x += W + 8; wrapped = true; }
        if (g.x > W + 4) { g.x -= W + 8; wrapped = true; }
        if (g.y < -4) { g.y += H + 8; wrapped = true; }
        if (g.y > H + 4) { g.y -= H + 8; wrapped = true; }
        if (wrapped) {
          g.px = g.x;
          g.py = g.y;
        }
      }
    }

    function draw() {
      // Translucent paper veil: old strokes wash out like diluted ink
      ctx.fillStyle = 'rgba(250, 249, 245, 0.028)';
      ctx.fillRect(0, 0, W, H);

      ctx.lineCap = 'round';
      for (const g of agents) {
        ctx.strokeStyle = `rgba(28, 27, 23, ${g.d * (0.55 + 0.45 * order)})`;
        ctx.lineWidth = g.w;
        ctx.beginPath();
        ctx.moveTo(g.px, g.py);
        ctx.lineTo(g.x, g.y);
        ctx.stroke();
      }
    }

    function frame(t: number) {
      if (!running) return;
      const dt = Math.min((t - last) / 1000, 0.05);
      last = t;
      step(dt);
      draw();
      raf = requestAnimationFrame(frame);
    }

    function start() {
      if (running || reduced) return;
      running = true;
      last = performance.now();
      raf = requestAnimationFrame(frame);
    }

    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    resize();
    addEventListener('resize', () => {
      // Ignore mobile URL-bar height jitter; only rebuild on real changes
      const rect = canvas.getBoundingClientRect();
      if (Math.abs(rect.width - W) < 1 && Math.abs(rect.height - H) < 120) return;
      stop();
      resize();
      staticFallbackOr(start);
    });

    function warmup(steps: number) {
      for (let i = 0; i < steps; i++) {
        step(1 / 60);
        draw();
      }
    }

    function staticFallbackOr(go: () => void) {
      if (reduced) {
        // One quiet, pre-run composition instead of motion
        order = 0.4;
        warmup(700);
      } else {
        // Arrive with ink already flowing
        order = 0.12;
        warmup(160);
        go();
      }
    }

    // Pause off-screen and when the tab is hidden
    new IntersectionObserver(
      ([e]) => (e.isIntersecting ? start() : stop()),
      { threshold: 0.05 }
    ).observe(canvas);

    document.addEventListener('visibilitychange', () =>
      document.hidden ? stop() : start()
    );

    staticFallbackOr(start);
  }
</script>
