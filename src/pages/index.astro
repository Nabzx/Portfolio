---
import Base from '../layouts/Base.astro';
import InkAgents from '../components/InkAgents.astro';

const featured = [
  {
    href: '/projects/cooperative-ai',
    eyebrow: 'Undergraduate dissertation',
    title: 'Cooperative Capabilities of AI Systems',
    text: 'How does cooperation emerge between learning agents? PPO agents trained in PettingZoo environments, studied under communication bandwidth constraints and varied reward design — with a counterintuitive finding about selfish incentives.',
    stack: 'PyTorch · PettingZoo · MARL · Reinforcement Learning',
  },
  {
    href: '/projects/neuroplastic-collective-intelligence',
    eyebrow: 'Ongoing research',
    title: 'Neuroplastic Collective Intelligence',
    text: 'Can communication mechanisms borrowed from computational neuroscience improve coordination in collective AI? Hebbian-inspired plasticity, adaptive communication graphs and information-theoretic analysis of emergent behaviour.',
    stack: 'PyTorch · PettingZoo · NetworkX · Information Theory',
  },
  {
    href: '/projects/humanitarian-aid-platform',
    eyebrow: 'First place — IBM × Capital One Hackathon',
    title: 'Humanitarian Aid Platform',
    text: 'An aid-allocation system for charities serving humanitarian camps, built privacy-first: a locally hosted language model and a custom predictive model, so no beneficiary data ever left the organisation’s control.',
    stack: 'Local LLMs · Predictive Modelling · Responsible AI',
  },
];

const additional = [
  {
    title: 'BidNet',
    year: '2026',
    text: 'A compute-aware neural architecture where expert modules bid for computation via a differentiable auction — roughly 3× less compute at comparable CIFAR-10 accuracy, with emergent expert specialisation.',
    stack: 'PyTorch · NumPy',
  },
  {
    title: 'FianchettoX',
    year: '2025',
    text: 'An explainable chess engine in C++ — bitboards, alpha-beta pruning and transposition tables searching 6–10 ply in under 150 ms, with neural evaluation served over ONNX across Dockerised microservices.',
    stack: 'C++ · ONNX · Docker · Next.js',
  },
  {
    title: 'Self-Learning Systems — Preprint',
    year: '2025',
    text: 'An investigative preprint examining self-learning AI systems, published on Zenodo. The groundwork that led to BidNet and a continuing interest in algorithmic information theory.',
    stack: 'Independent Research',
  },
  {
    title: 'ICU Risk Predictor',
    year: '2025',
    text: 'A clinical risk-prediction tool using k-nearest-neighbour search over vector embeddings of patient data — built while self-studying Bishop’s Pattern Recognition and Machine Learning.',
    stack: 'Python · Scikit-learn · Embeddings',
  },
  {
    title: 'Lecture Structuring Tool',
    year: '2025',
    text: 'An assistive transcription tool for students with specific learning disabilities, restructuring lecture content in real time into clear, navigable notes.',
    stack: 'Python · Speech-to-Text · LLMs',
  },
  {
    title: 'Tin Sentiment Bot',
    year: '2025',
    text: 'A production NLP system built at Minexx — GDELT ingestion, multilingual processing and PostgreSQL warehousing, issuing real-time buy/sell/hold signals for the tin market.',
    stack: 'Python · NLTK · PostgreSQL · GCP',
  },
];

const timeline = [
  {
    date: '2026',
    title: 'BSc Software Engineering — University of Leicester',
    role: 'First Class Honours · 80% · top 5% of cohort',
    text: 'Dissertation on cooperative AI systems, now being prepared for workshop submission. Four years spent moving between theory and engineering — and learning that the interesting problems live in between.',
  },
  {
    date: '2024 — 2026',
    title: 'Minexx',
    role: 'Software Engineer Intern',
    text: 'Built the data and NLP backbone for a platform supporting responsible mineral trading across sub-Saharan Africa: async microservices processing 3,000+ multilingual articles a day, a production sentiment system issuing real-time trading signals for the tin market, and a full migration of the company’s AI infrastructure to GCP serving 1M+ requests a day.',
  },
  {
    date: '2025',
    title: 'IBM × Capital One Hackathon',
    role: 'First Place',
    text: 'Won with a privacy-first humanitarian aid platform — and came away convinced that capable systems must also be accountable ones.',
  },
  {
    date: '2024 — 2026',
    title: 'Founders Society',
    role: 'Founder & President',
    text: 'Launched the university’s first student-run startup accelerator, leading 100+ participants and reaching an audience of over 500,000 — building the kind of ambitious, interdisciplinary community I want to work within.',
  },
  {
    date: 'School years',
    title: 'Competitive Debating',
    role: 'Top 30 worldwide — Oxford Schools’',
    text: '4× regional champion and 3× national finalist. Where I learned to hold an argument to a standard — a habit that transferred directly to research.',
  },
];

const skills = [
  {
    group: 'Languages',
    items: ['Python', 'C++', 'Java', 'TypeScript', 'SQL', 'Bash'],
  },
  {
    group: 'AI & Machine Learning',
    items: [
      'PyTorch',
      'Reinforcement Learning',
      'Multi-Agent Systems',
      'LLMs',
      'TensorFlow',
      'Scikit-learn',
      'Hugging Face',
      'NumPy',
      'NetworkX',
      'Pandas',
    ],
  },
  {
    group: 'Systems & Infrastructure',
    items: ['GCP', 'AWS', 'Docker', 'PostgreSQL', 'Redis', 'Kafka', 'Next.js', 'Git', 'APIs'],
  },
];

const interests = [
  'Multi-Agent Reinforcement Learning',
  'Collective Intelligence',
  'Emergent Behaviour',
  'Agentic AI',
  'Computational Neuroscience',
  'AI Safety',
  'Interpretability',
  'Adaptive Communication',
  'Distributed Intelligence',
];
---

<Base
  title="Nabil Shah — AI Researcher & Engineer"
  description="AI researcher and engineer working on multi-agent reinforcement learning, collective intelligence and emergent behaviour. Building intelligent systems that learn together."
>
  <!-- ============================== HERO ============================== -->
  <section class="hero">
    <InkAgents />
    <div class="wrap hero-inner">
      <figure class="hero-portrait">
        <img src="/portrait.svg" alt="Ink-wash portrait of Nabil Shah" width="520" height="640" />
      </figure>
      <div class="hero-text">
        <p class="eyebrow hero-eyebrow">Nabil Shah — AI Researcher &amp; Engineer</p>
        <h1 class="hero-title">
          <span class="line"><span class="line-inner">Building intelligent</span></span>
          <span class="line"><span class="line-inner">systems that</span></span>
          <span class="line"><span class="line-inner"><em>learn together.</em></span></span>
        </h1>
        <p class="hero-sub">
          I build AI systems inspired by cooperation, adaptation and emergence — combining
          research with engineering to explore how collections of intelligent agents can solve
          problems that no individual agent can.
        </p>
        <div class="hero-ctas">
          <a class="cta cta-primary" href="#work">View projects</a>
          <a class="cta cta-ghost" href="#about">About me</a>
        </div>
      </div>
    </div>
    <p class="hero-scroll" aria-hidden="true">Scroll</p>
  </section>

  <!-- ============================== ABOUT ============================== -->
  <section class="section" id="about">
    <div class="wrap about-grid">
      <div class="about-aside reveal">
        <p class="eyebrow">About</p>
        <blockquote class="about-quote">
          Technology should not simply become more capable. It should become more
          understandable, collaborative and beneficial.
        </blockquote>
      </div>
      <div class="prose about-prose reveal">
        <p>
          I’m a software engineer turned AI researcher, recently graduated from the University of
          Leicester with First Class Honours — finishing in the top five per cent of my cohort. I’m
          drawn to problems that demand both theoretical understanding and practical engineering,
          and I’ve found that the most interesting work happens where the two refuse to separate.
        </p>
        <p>
          I believe the future of AI lies not only in larger models, but in systems that can
          <em>reason, coordinate and adapt collectively</em>. Much of what I study is intelligence
          that emerges through interaction rather than explicit programming — how simple agents
          cooperate, communicate and self-organise into something greater than any of them. That
          conviction runs through my dissertation on multi-agent reinforcement learning, my current
          research on neuroplastic communication, and the systems I’ve shipped in industry.
        </p>
        <p>
          I originally intended to study medicine. The ambition to improve lives never left — only
          the instruments changed. Today that means working toward doctoral research in
          reinforcement learning and collective intelligence, while building AI for places that need
          it most. Outside of research I train for endurance events, compete in hackathons and read
          philosophy — all, in their own way, practice in staying with hard problems for a long
          time.
        </p>
      </div>
    </div>
  </section>

  <!-- ========================= FEATURED WORK ========================== -->
  <section class="section" id="work">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Selected work</p>
      </div>
      <div class="featured">
        {
          featured.map((p) => (
            <a class="feature reveal" href={p.href}>
              <div class="feature-meta">
                <p class="eyebrow">{p.eyebrow}</p>
                <p class="feature-stack">{p.stack}</p>
              </div>
              <div class="feature-body">
                <h2 class="feature-title">{p.title}</h2>
                <p class="feature-text">{p.text}</p>
                <span class="feature-more">Read the project<span class="feature-arrow" aria-hidden="true">→</span></span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======================= ADDITIONAL PROJECTS ====================== -->
  <section class="section" id="projects">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Further projects</p>
      </div>
      <div class="grid">
        {
          additional.map((p) => (
            <article class="card reveal">
              <div class="card-top">
                <h3 class="card-title">{p.title}</h3>
                <p class="card-year">{p.year}</p>
              </div>
              <p class="card-text">{p.text}</p>
              <p class="card-stack">{p.stack}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================ EXPERIENCE ========================== -->
  <section class="section" id="experience">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Experience</p>
      </div>
      <ol class="timeline">
        {
          timeline.map((t) => (
            <li class="tl-item reveal">
              <p class="tl-date">{t.date}</p>
              <div class="tl-body">
                <h3 class="tl-title">{t.title}</h3>
                <p class="tl-role">{t.role}</p>
                <p class="tl-text">{t.text}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============================ RESEARCH ============================ -->
  <section class="section" id="research">
    <div class="wrap research-grid">
      <div class="reveal">
        <p class="eyebrow">Research interests</p>
        <h2 class="research-title">Intelligence, emerging through interaction.</h2>
      </div>
      <div class="prose research-prose reveal">
        <p>
          My research asks a single question from several directions: <em>how does capable,
          coordinated behaviour arise from collections of simpler learners?</em> Multi-agent
          reinforcement learning gives that question a laboratory — agents whose incentives,
          communication channels and environments we can shape, and whose emergent strategies we
          can measure. My dissertation showed me how sensitive these systems are to what we reward
          and how much the agents may say to each other; my current work on neuroplastic
          communication asks whether the answer to better coordination lies in
          <em>how connections themselves learn</em>, borrowing plasticity mechanisms from
          computational neuroscience.
        </p>
        <p>
          The same question scales upward. As AI systems become agentic — acting, delegating and
          negotiating over long horizons — coordination stops being an academic curiosity and
          becomes a safety property. I care about interpretability and AI safety for that reason:
          systems whose collective behaviour we cannot explain are systems we cannot responsibly
          deploy. Emergence should be something we understand well enough to design for, not
          something we discover in production.
        </p>
        <p>
          Long term, I want to contribute to frontier research in reinforcement learning and
          collective intelligence — and to carry that research into systems that are safe, scalable
          and genuinely beneficial, particularly in under-resourced parts of the world.
        </p>
        <ul class="interest-list" aria-label="Research areas">
          {interests.map((i) => <li>{i}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- ============================= SKILLS ============================= -->
  <section class="section" id="skills">
    <div class="wrap">
      <div class="section-head reveal">
        <p class="eyebrow">Skills</p>
      </div>
      <div class="skills">
        {
          skills.map((s) => (
            <div class="skill-col reveal">
              <h3 class="skill-group">{s.group}</h3>
              <ul class="skill-list">
                {s.items.map((i) => <li>{i}</li>)}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================= CONTACT ============================ -->
  <section class="section contact" id="contact">
    <div class="wrap reveal">
      <p class="eyebrow">Contact</p>
      <h2 class="contact-title">
        If you’re working on research, ambitious systems or ideas worth taking seriously — I’d
        like to hear about it.
      </h2>
      <a class="contact-mail ink-link" href="mailto:nabilshahx@gmail.com">nabilshahx@gmail.com</a>
      <div class="contact-links">
        <a class="ink-link" href="https://github.com/Nabzx" rel="noopener">GitHub</a>
        <a class="ink-link" href="https://linkedin.com/in/nabilshah" rel="noopener">LinkedIn</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ------------------------------- hero ---------------------------- */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    width: 100%;
    padding-block: 7.5rem 5rem;
  }

  .hero-text {
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    margin-bottom: 1.75rem;
    animation: fade-in 1.2s var(--ease-out) 0.9s backwards;
  }

  .hero-title {
    font-size: clamp(2.5rem, 7.8vw, 6.4rem);
    font-weight: 500;
  }

  .hero-title em {
    font-style: italic;
    font-weight: 400;
  }

  .line {
    display: block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
  }

  .line-inner {
    display: block;
    transform: translateY(110%);
    animation: rise 1.1s var(--ease-out) forwards;
  }

  .line:nth-child(1) .line-inner { animation-delay: 0.15s; }
  .line:nth-child(2) .line-inner { animation-delay: 0.3s; }
  .line:nth-child(3) .line-inner { animation-delay: 0.45s; }

  @keyframes rise {
    to { transform: translateY(0); }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .hero-sub {
    max-width: 34rem;
    margin-top: 2rem;
    color: var(--ink-strong);
    animation: fade-in 1.2s var(--ease-out) 1.05s backwards;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.75rem;
    animation: fade-in 1.2s var(--ease-out) 1.2s backwards;
  }

  .cta {
    display: inline-block;
    padding: 0.85rem 1.9rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--ink);
    transition:
      background 0.3s var(--ease-out),
      color 0.3s var(--ease-out);
  }

  .cta-primary {
    background: var(--ink);
    color: var(--paper);
  }

  .cta-primary:hover {
    background: transparent;
    color: var(--ink);
  }

  .cta-ghost {
    color: var(--ink);
  }

  .cta-ghost:hover {
    background: var(--ink);
    color: var(--paper);
  }

  .hero-portrait {
    position: absolute;
    z-index: 1;
    right: 0;
    top: 54%;
    transform: translateY(-52%);
    width: clamp(15rem, 27vw, 23rem);
    animation: fade-in 1.8s var(--ease-out) 0.7s backwards;
  }

  .hero-portrait img {
    width: 100%;
    height: auto;
    mix-blend-mode: multiply;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ink-faint);
    animation: fade-in 1.2s var(--ease-out) 2s backwards;
  }

  @media (max-width: 56rem) {
    .hero-inner {
      padding-top: 6rem;
    }

    .hero-portrait {
      position: static;
      transform: none;
      width: min(13rem, 55vw);
      margin-bottom: 1.5rem;
    }

    .hero-scroll {
      display: none;
    }
  }

  /* ------------------------------- about --------------------------- */
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 7fr);
    gap: clamp(2.5rem, 6vw, 5.5rem);
  }

  .about-quote {
    margin-top: 1.5rem;
    font-family: var(--serif);
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    line-height: 1.45;
    font-weight: 400;
  }

  .about-prose {
    color: var(--ink-strong);
    max-width: 40rem;
  }

  .about-prose em {
    color: var(--ink);
  }

  @media (max-width: 56rem) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ------------------------- featured work ------------------------- */
  .featured {
    display: grid;
  }

  .feature {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 7fr);
    gap: clamp(1.5rem, 5vw, 5.5rem);
    padding-block: clamp(2.5rem, 5vw, 3.75rem);
    text-decoration: none;
    border-top: 1px solid var(--line);
  }

  .feature:last-child {
    border-bottom: 1px solid var(--line);
  }

  .feature-meta {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .feature-stack {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
  }

  .feature-title {
    font-size: clamp(1.7rem, 3.4vw, 2.6rem);
    transition: transform 0.5s var(--ease-out);
  }

  .feature:hover .feature-title {
    transform: translateX(0.5rem);
  }

  .feature-text {
    margin-top: 1rem;
    max-width: 38rem;
    color: var(--ink-strong);
  }

  .feature-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-soft);
    transition: color 0.3s var(--ease-out);
  }

  .feature:hover .feature-more {
    color: var(--ink);
  }

  .feature-arrow {
    transition: transform 0.4s var(--ease-out);
  }

  .feature:hover .feature-arrow {
    transform: translateX(0.35rem);
  }

  @media (max-width: 56rem) {
    .feature {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  /* --------------------------- project grid ------------------------ */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }

  .card {
    background: var(--paper);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 2rem 1.75rem 1.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    transition: background 0.35s var(--ease-out);
  }

  .card:hover {
    background: var(--paper-deep);
  }

  .card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .card-title {
    font-size: 1.3rem;
  }

  .card-year {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-faint);
  }

  .card-text {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--ink-strong);
    flex: 1;
  }

  .card-stack {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
  }

  /* ----------------------------- timeline -------------------------- */
  .timeline {
    list-style: none;
    padding: 0;
    max-width: 52rem;
  }

  .tl-item {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    position: relative;
    padding-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }

  .tl-item:last-child {
    padding-bottom: 0;
  }

  /* hairline spine with an ink dot per entry */
  .tl-item::before {
    content: '';
    position: absolute;
    left: 11.4rem;
    top: 0.55em;
    bottom: -0.55em;
    width: 1px;
    background: var(--line);
  }

  .tl-item:last-child::before {
    display: none;
  }

  .tl-item::after {
    content: '';
    position: absolute;
    left: calc(11.4rem - 3px);
    top: 0.45em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--ink);
  }

  .tl-date {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--ink-soft);
    text-align: right;
    padding-top: 0.35em;
  }

  .tl-body {
    padding-left: clamp(1.5rem, 3vw, 2.5rem);
  }

  .tl-title {
    font-size: 1.35rem;
  }

  .tl-role {
    margin-top: 0.3rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .tl-text {
    margin-top: 0.8rem;
    font-size: 0.98rem;
    color: var(--ink-strong);
    max-width: 36rem;
  }

  @media (max-width: 40rem) {
    .tl-item {
      grid-template-columns: 1fr;
      gap: 0.4rem;
      padding-left: 1.5rem;
    }

    .tl-item::before {
      left: 0.2rem;
    }

    .tl-item::after {
      left: calc(0.2rem - 3px);
    }

    .tl-date {
      text-align: left;
      padding-left: 0;
    }

    .tl-body {
      padding-left: 0;
    }
  }

  /* ----------------------------- research -------------------------- */
  .research-grid {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 7fr);
    gap: clamp(2.5rem, 6vw, 5.5rem);
  }

  .research-title {
    margin-top: 1.5rem;
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    line-height: 1.3;
  }

  .research-prose {
    color: var(--ink-strong);
    max-width: 40rem;
  }

  .research-prose em {
    color: var(--ink);
  }

  .interest-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.6rem;
    list-style: none;
    padding: 0;
    margin-top: 2.5rem;
  }

  .interest-list li {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--line);
    color: var(--ink-soft);
  }

  @media (max-width: 56rem) {
    .research-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ------------------------------ skills --------------------------- */
  .skills {
    display: grid;
